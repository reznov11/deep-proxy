# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ELASTICSEARCH_HOSTS overrides ELASTICSEARCH_URL when set.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_HOSTS=https://localhost:9200
ELASTICSEARCH_INDEX=proxy-logs
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=false
# ELASTICSEARCH_CA_CERTS=

# Ports
PROXY_PORT=9090
DASHBOARD_PORT=8001

# Logging
MAX_BODY_STORAGE_BYTES=1048576

# mitmproxy addon POST /api/ingest/flow — set a secret and match DEEP_PROXY_INGEST_TOKEN when running mitmdump
INGEST_API_TOKEN=

# MITM HTTPS (install ca.crt as trusted root on clients). Ports: comma-separated.
# MITM_ENABLED=false
# MITM_CA_CERT_PATH=
# MITM_CA_KEY_PATH=
# MITM_TLS_PORTS=443,8443

# Dashboard (session cookie auth)
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=

# Proxy authentication
PROXY_USER=
PROXY_PASS=
PROXY_REQUIRE_AUTH=
