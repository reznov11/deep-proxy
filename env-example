# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ELASTICSEARCH_HOSTS overrides ELASTICSEARCH_URL when set.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_HOSTS=https://localhost:9200
ELASTICSEARCH_INDEX=proxy-logs
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=false
# ELASTICSEARCH_CA_CERTS=

# Ports
PROXY_PORT=9090
DASHBOARD_PORT=8001

# Logging
MAX_BODY_STORAGE_BYTES=1048576

# Optional: POST /api/ingest/flow — set a secret and send X-Deep-Proxy-Ingest-Token
INGEST_API_TOKEN=

# Dashboard (session cookie auth)
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=

# Proxy authentication (Basic Proxy-Authorization). Set both user and pass; leave empty to disable.
PROXY_USER=
PROXY_PASS=
# When true (default), require auth if PROXY_USER and PROXY_PASS are set. Set false for local testing only.
PROXY_REQUIRE_AUTH=true
# When true, failed auth (407) is stored in the dashboard; default false avoids noisy scans filling the log.
PROXY_LOG_AUTH_FAILURES=false
